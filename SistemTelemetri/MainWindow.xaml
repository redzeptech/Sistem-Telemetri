<Window x:Class="SistemTelemetri.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:SistemTelemetri.Converters"
        xmlns:local="clr-namespace:SistemTelemetri"
        xmlns:vm="clr-namespace:SistemTelemetri.ViewModels"
        xmlns:pf="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{x:Static local:UygulamaBilgisi.PencereBasligi}"
        Width="300"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        Foreground="White"
        FontSize="{Binding Ayarlar.YaziBoyutu}"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Loaded="MainWindow_OnLoaded">
    <Window.Resources>
        <pf:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:YukCubuguFircaDonusturucu x:Key="YukCubuguFirca" />
        <converters:NullDoubleToVisibilityConverter x:Key="NullDoubleToVisibility" />
        <converters:MetinHizalamaDonusturucu x:Key="MetinHizalama" />
        <converters:YuktenRenkDonusturucu x:Key="YukRenk" />

        <Style x:Key="SidebarText" TargetType="TextBlock">
            <Setter Property="TextAlignment"
                    Value="{Binding DataContext.Ayarlar.MetinHizalama, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MetinHizalama}}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource SidebarText}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.88" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="BodyText" TargetType="TextBlock" BasedOn="{StaticResource SidebarText}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Opacity" Value="0.95" />
        </Style>
        <Style x:Key="InceYukCubugu" TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Margin" Value="0,6,0,8" />
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="SicaklikCubugu" TargetType="ProgressBar" BasedOn="{StaticResource InceYukCubugu}" />

        <Style x:Key="TelemetriKarti" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="#22000000" />
            <Setter Property="BorderBrush" Value="#28FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
    </Window.Resources>

    <Border x:Name="DisKenarlik"
            BorderBrush="#35FFFFFF"
            BorderThickness="1"
            CornerRadius="18"
            Margin="10,10,10,10"
            SnapsToDevicePixels="True"
            ClipToBounds="True">
        <Grid>
            <Border x:Name="ArkaPlanKatmani"
                    CornerRadius="16"
                    Background="#6B0A0A12" />

            <Grid x:Name="IcOlcek">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding Ayarlar.UiOlcegi}" ScaleY="{Binding Ayarlar.UiOlcegi}" />
                </Grid.LayoutTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="AyarlarSutunuTanim" Width="0" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="20" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           Grid.ColumnSpan="2"
                           Margin="18,18,14,6"
                           LastChildFill="False">
                    <Button DockPanel.Dock="Right"
                            Content="⚙"
                            ToolTip="Ayarlar"
                            Padding="12,8"
                            Cursor="Hand"
                            Background="#25FFFFFF"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Command="{Binding AyarlariAcCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" CornerRadius="10" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#38FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Content="❌"
                            ToolTip="Kapat (çıkış)"
                            Padding="10,6"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Command="{Binding UygulamayiKapatCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            FontSize="13"
                            Opacity="0.28">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="kx" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="kx" Property="Background" Value="#33FF4444" />
                                        <Setter Property="Opacity" Value="1" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource SidebarText}"
                               Text="{x:Static local:UygulamaBilgisi.BaslikBanner}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.95"
                               TextWrapping="Wrap"
                               MaxWidth="220" />
                </DockPanel>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="18,0,18,8"
                        CornerRadius="8"
                        Padding="10,6"
                        Background="#AAFF0000"
                        Visibility="{Binding SicaklikAlarmGorunur, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SicaklikAlarmGorunur}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="SicaklikBannerPulse">
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.55"
                                                                 To="1"
                                                                 Duration="0:0:0.4" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="SicaklikBannerPulse" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="⚠️ SICAKLIK KRİTİK!"
                               FontWeight="Bold"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Foreground="White" />
                </Border>

                <ScrollViewer x:Name="IcerikSurukleyici"
                              Grid.Row="2"
                              Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="18,8,18,10"
                              Background="Transparent">
                    <StackPanel>
                        <StackPanel Visibility="{Binding Ayarlar.GosterZaman, Converter={StaticResource BoolToVis}}">
                            <Border Style="{StaticResource TelemetriKarti}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="ZAMAN" />
                                    <TextBlock Style="{StaticResource BodyText}"
                                               Text="{Binding ClockText}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,2" />
                                    <TextBlock Style="{StaticResource SidebarText}"
                                               Text="{Binding TurkishDateText}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Opacity="0.8" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding Ayarlar.GosterIslemci, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource TelemetriKarti}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IslemciBolgesiParliyor}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#88FFB84D" />
                                                    <Setter Property="Background" Value="#38FFAA44" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FFFFB020" BlurRadius="20" ShadowDepth="0" Opacity="0.55" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IslemciSicaklikKritik}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#FFFF2222" />
                                                    <Setter Property="Background" Value="#48FF0000" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FFFF0000" BlurRadius="18" ShadowDepth="0" Opacity="0.7" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="İŞLEMCİ" />
                                        <TextBlock Style="{StaticResource BodyText}"
                                                   Text="{Binding Donanim.IslemciModelBasligi}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6"
                                                   Opacity="0.98" />
                                        <Canvas Width="280" Height="52" HorizontalAlignment="Left" ClipToBounds="True" Margin="0,0,0,4">
                                            <Polyline StrokeThickness="2.2"
                                                      StrokeLineJoin="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeStartLineCap="Round"
                                                      Points="{Binding CpuSparkNoktalari}"
                                                      Stroke="{Binding Donanim.IslemciYukuYuzdesi, Converter={StaticResource YukRenk}, FallbackValue=#74B9FF}" />
                                        </Canvas>
                                        <ProgressBar Style="{StaticResource InceYukCubugu}"
                                                     Visibility="{Binding Donanim.IslemciYukuYuzdesi, Converter={StaticResource NullDoubleToVisibility}}"
                                                     Value="{Binding Donanim.IslemciYukuYuzdesi, TargetNullValue=0}"
                                                     Foreground="{Binding Donanim.IslemciYukuYuzdesi, Converter={StaticResource YukCubuguFirca}}" />
                                        <TextBlock Style="{StaticResource BodyText}" Text="{Binding Donanim.IslemciYuku}" />
                                        <TextBlock Style="{StaticResource SidebarText}"
                                                   Text="İzlek yükleri (P: performans, E: verimlilik — hibrit CPU)"
                                                   FontSize="10"
                                                   Opacity="0.65"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,4" />
                                        <ItemsControl ItemsSource="{Binding Donanim.CekirdekYukleri}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="6" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:CekirdekYukuOgesi}">
                                                    <StackPanel Margin="0,0,4,6" MinWidth="36">
                                                        <TextBlock Text="{Binding Etiket}"
                                                                   FontSize="9"
                                                                   Opacity="0.72"
                                                                   HorizontalAlignment="Center" />
                                                        <ProgressBar Height="5"
                                                                     Margin="0,3,0,0"
                                                                     Style="{StaticResource InceYukCubugu}"
                                                                     Maximum="100"
                                                                     Value="{Binding Yuzde}"
                                                                     Foreground="{Binding Yuzde, Converter={StaticResource YukRenk}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="🌡️"
                                                       FontSize="14"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Donanim.IslemciSicaklikUyari}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard Name="IslemciUyarSb">
                                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                             From="0.35"
                                                                                             To="1"
                                                                                             Duration="0:0:0.45" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="IslemciUyarSb" />
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1">
                                                <ProgressBar Style="{StaticResource SicaklikCubugu}"
                                                             Maximum="100"
                                                             Value="{Binding Donanim.IslemciSicaklikDegeri}"
                                                             Visibility="{Binding Donanim.IslemciSicaklikDegeri, Converter={StaticResource NullDoubleToVisibility}}"
                                                             Foreground="{Binding Donanim.IslemciSicaklikDegeri, Converter={StaticResource YukRenk}, FallbackValue=#E17055}" />
                                                <TextBlock Style="{StaticResource SidebarText}" Text="{Binding Donanim.IslemciSicakligi}" FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Style="{StaticResource BodyText}"
                                                   Margin="0,6,0,0"
                                                   Text="{Binding Donanim.IslemciFanHizMetni}"
                                                   FontSize="12"
                                                   Opacity="0.92" />
                                        <TextBlock Style="{StaticResource SidebarText}"
                                                   Text="{Binding Donanim.IslemciFanYuzdeMetni}"
                                                   FontSize="11"
                                                   Opacity="0.85" />
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="14"
                                        IsHitTestVisible="False"
                                        Panel.ZIndex="2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#88FF0000" />
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IslemciSicaklikKritik}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard Name="IslemciKirmiziPulse">
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0.12"
                                                                                 To="0.55"
                                                                                 Duration="0:0:0.45" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="IslemciKirmiziPulse" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding Ayarlar.GosterBellek, Converter={StaticResource BoolToVis}}">
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource TelemetriKarti}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BellekBolgesiParliyor}" Value="True">
                                                <Setter Property="BorderBrush" Value="#88FFB84D" />
                                                <Setter Property="Background" Value="#38FFAA44" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#FFFFB020" BlurRadius="20" ShadowDepth="0" Opacity="0.55" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="BELLEK" />
                                    <TextBlock Style="{StaticResource SidebarText}"
                                               Text="{Binding Donanim.BellekModulDetayMetni}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Opacity="0.88"
                                               Margin="0,0,0,6" />
                                    <Canvas Width="280" Height="52" HorizontalAlignment="Left" ClipToBounds="True" Margin="0,0,0,4">
                                        <Polyline StrokeThickness="2.2"
                                                  StrokeLineJoin="Round"
                                                  Points="{Binding RamSparkNoktalari}"
                                                  Stroke="{Binding Donanim.BellekYukuYuzdesi, Converter={StaticResource YukRenk}, FallbackValue=#55E0AA}" />
                                    </Canvas>
                                    <ProgressBar Style="{StaticResource InceYukCubugu}"
                                                 Visibility="{Binding Donanim.BellekYukuYuzdesi, Converter={StaticResource NullDoubleToVisibility}}"
                                                 Value="{Binding Donanim.BellekYukuYuzdesi, TargetNullValue=0}"
                                                 Foreground="{Binding Donanim.BellekYukuYuzdesi, Converter={StaticResource YukCubuguFirca}}" />
                                    <TextBlock Style="{StaticResource BodyText}" Text="{Binding Donanim.BellekKullanimi}" />
                                    <TextBlock Style="{StaticResource SidebarText}"
                                               Text="{Binding Donanim.BellekBosAlani}"
                                               FontSize="12"
                                               Opacity="0.85" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding Ayarlar.GosterEkranKarti, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource TelemetriKarti}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GpuBolgesiParliyor}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#88FFB84D" />
                                                    <Setter Property="Background" Value="#38FFAA44" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FFFFB020" BlurRadius="20" ShadowDepth="0" Opacity="0.55" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding GpuSicaklikKritik}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#FFFF2222" />
                                                    <Setter Property="Background" Value="#48FF0000" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FFFF0000" BlurRadius="18" ShadowDepth="0" Opacity="0.7" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="EKRAN KARTI" />
                                        <TextBlock Style="{StaticResource BodyText}" Text="{Binding Donanim.GrafikBirimi}" FontSize="12" Opacity="0.9" />
                                        <Canvas Width="280" Height="52" HorizontalAlignment="Left" ClipToBounds="True" Margin="0,4,0,4">
                                            <Polyline StrokeThickness="2.2"
                                                      StrokeLineJoin="Round"
                                                      Points="{Binding GpuSparkNoktalari}"
                                                      Stroke="{Binding Donanim.EkranKartiYukuYuzdesi, Converter={StaticResource YukRenk}, FallbackValue=#A29BFE}" />
                                        </Canvas>
                                        <ProgressBar Style="{StaticResource InceYukCubugu}"
                                                     Visibility="{Binding Donanim.EkranKartiYukuYuzdesi, Converter={StaticResource NullDoubleToVisibility}}"
                                                     Value="{Binding Donanim.EkranKartiYukuYuzdesi, TargetNullValue=0}"
                                                     Foreground="{Binding Donanim.EkranKartiYukuYuzdesi, Converter={StaticResource YukCubuguFirca}}" />
                                        <TextBlock Style="{StaticResource BodyText}" Text="{Binding Donanim.EkranKartiYuku}" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="🌡️"
                                                       FontSize="14"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Donanim.GpuSicaklikUyari}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard Name="GpuUyarSb">
                                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                             From="0.35"
                                                                                             To="1"
                                                                                             Duration="0:0:0.45" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="GpuUyarSb" />
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1">
                                                <ProgressBar Style="{StaticResource SicaklikCubugu}"
                                                             Maximum="100"
                                                             Value="{Binding Donanim.GpuSicaklikDegeri}"
                                                             Visibility="{Binding Donanim.GpuSicaklikDegeri, Converter={StaticResource NullDoubleToVisibility}}"
                                                             Foreground="{Binding Donanim.GpuSicaklikDegeri, Converter={StaticResource YukRenk}, FallbackValue=#E17055}" />
                                                <TextBlock Style="{StaticResource SidebarText}" Text="{Binding Donanim.EkranKartiSicakligi}" FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Style="{StaticResource BodyText}"
                                                   Margin="0,6,0,0"
                                                   Text="{Binding Donanim.GpuFanHizMetni}"
                                                   FontSize="12"
                                                   Opacity="0.92" />
                                        <TextBlock Style="{StaticResource SidebarText}"
                                                   Text="{Binding Donanim.GpuFanYuzdeMetni}"
                                                   FontSize="11"
                                                   Opacity="0.85" />
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="14"
                                        IsHitTestVisible="False"
                                        Panel.ZIndex="2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#88FF0000" />
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GpuSicaklikKritik}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard Name="GpuKirmiziPulse">
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0.12"
                                                                                 To="0.55"
                                                                                 Duration="0:0:0.45" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="GpuKirmiziPulse" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding Ayarlar.GosterDepolama, Converter={StaticResource BoolToVis}}">
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource TelemetriKarti}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DepolamaBolgesiParliyor}" Value="True">
                                                <Setter Property="BorderBrush" Value="#88FFB84D" />
                                                <Setter Property="Background" Value="#38FFAA44" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#FFFFB020" BlurRadius="20" ShadowDepth="0" Opacity="0.55" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DiskDarbogazUyari}" Value="True">
                                                <Setter Property="BorderBrush" Value="#FFFF6666" />
                                                <Setter Property="Background" Value="#33FF4444" />
