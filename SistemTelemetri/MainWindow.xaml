                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="AyarlarPaneliKapsayici"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.94"
                                                     Duration="0:0:0.28">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
